{
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "DEVCONTAINER_UPDATE_CHECK_TTL_SECONDS": "86400",
    "DOCKER_CLI_HINTS": "false",
    "MEWTWO_OPS_TERMINAL": "vscode",
    "MEWTWO_SSH_IDENTITY_MODE": "agent"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "codeandstuff.package-json-upgrade",
        "davidanson.vscode-markdownlint",
        "eamodio.gitlens",
        "editorconfig.editorconfig",
        "emilast.logfilehighlighter",
        "ezforo.copy-relative-path-and-line-numbers",
        "fabiospampinato.vscode-terminals",
        "mikestead.dotenv",
        "ms-azuretools.vscode-containers",
        "ms-vscode-remote.remote-containers",
        "openai.chatgpt",
        "tamasfe.even-better-toml",
        "timonwong.shellcheck",
        "unional.vscode-sort-package-json",
        "wayou.vscode-todo-highlight",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "mounts": [
    "source=mewtwo-rtk-config,target=/home/vscode/.config/rtk,type=volume",
    "source=mewtwo-rtk-data,target=/home/vscode/.local/share/rtk,type=volume",
    "source=mewtwo-uv-cache,target=/home/vscode/.cache/uv,type=volume",
    "source=mewtwo-npm-cache,target=/home/vscode/.npm,type=volume",
    "source=mewtwo-codex-home,target=/home/vscode/.codex,type=volume"
  ],
  "name": "mewtwo-dev",
  "postAttachCommand": "bash .devcontainer/scripts/show-update-status.sh || true",
  "postCreateCommand": "bash .devcontainer/scripts/post-create.sh",
  "postStartCommand": "bash .devcontainer/scripts/check-container-updates.sh || true",
  "remoteEnv": {
    "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}"
  },
  "remoteUser": "vscode",
  "runArgs": ["--hostname=mewtwo-dev", "--add-host=host.docker.internal:host-gateway", "--cap-add=SYS_ADMIN", "--security-opt=seccomp=unconfined"]
}
