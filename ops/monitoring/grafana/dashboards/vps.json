{
  "uid": "gta-rp-vps",
  "title": "GTA RP - VPS",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["gta-rp", "vps"],
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "CPU",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "RAM disponible",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{ "expr": "node_memory_MemAvailable_bytes", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Disque / utilise",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "100 * (1 - node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"rootfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"rootfs\"})", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Reseau",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [{ "expr": "sum by (device) (rate(node_network_receive_bytes_total[5m]) + rate(node_network_transmit_bytes_total[5m]))", "refId": "A" }]
    }
  ]
}
