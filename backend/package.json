{
  "name": "gta-rp-population-graph-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "biome lint .",
    "check": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:ensure": "tsx src/db/ensure-database.ts",
    "db:migrate": "tsx src/db/migrate.ts up",
    "db:migrate:undo": "tsx src/db/migrate.ts down",
    "db:migrate:pending": "tsx src/db/migrate.ts pending",
    "db:migrate:executed": "tsx src/db/migrate.ts executed",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/migrate.ts down --all && tsx src/db/migrate.ts up && tsx src/db/seed.ts"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pg": "^8.21.0",
    "present": "^1.0.0",
    "scripts": "^0.1.0",
    "sequelize": "^6.37.8",
    "umzug": "^3.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "overrides": {
    "sequelize": {
      "uuid": "^11.1.1"
    }
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
