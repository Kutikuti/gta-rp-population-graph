NODE_ENV=development
PORT=4000

# Frontend autorise pour CORS en developpement.
WEB_CLIENT_URL=http://localhost:5173

# PostgreSQL local.
# Depuis le host WSL : DB_HOST=localhost.
# Depuis le devcontainer vers un Postgres Docker expose sur le host :
# DB_HOST=host.docker.internal.
DB_NAME=gta_rp_population_graph
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_SSL=false
DB_MAINTENANCE_NAME=postgres

# Session serveur pour Google OAuth.
# Generer une valeur longue et aleatoire en local et en production.
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=gta_rp_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# Google OAuth.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Limitation d'abus.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CHANGE_REQUEST_RATE_LIMIT_MAX=10

# Uploads de photos personnages.
# PHOTO_STORAGE_DIR est relatif au dossier backend et doit rester hors Git.
PHOTO_UPLOAD_MAX_BYTES=2097152
PHOTO_UPLOAD_RATE_LIMIT_MAX=6
PHOTO_STORAGE_DIR=storage/uploads
PHOTO_DRAFT_MAX_AGE_HOURS=24
